# .env.example — JSON Directory Harvester
# Copy this file to .env and fill in your values.
# .env is listed in .gitignore and will never be committed.

# Override the API endpoint URL at runtime (optional).
# Takes precedence over the url value in config.yaml.
SCRAPER_API_URL=

# API key injected as a Bearer token in the Authorization header (optional).
# Takes precedence over any Authorization header set in config.yaml.
SCRAPER_API_KEY=
